---
import Base from '../layouts/Base.astro';
---
<Base title="About">
  <div class="about-page">

    <div class="about-header">
      <span class="about-eyebrow">About</span>
      <h1 class="about-name">New Ontologies</h1>
    </div>

    <div class="about-body">

      <div class="about-content">
        <p class="about-text">Ontology: <a href="https://en.wikipedia.org/wiki/Ancient_Greek" target="_blank" rel="noopener">ancient Greek</a> terms ὄντως (<em>ontos</em>, meaning 'being') and λογία (<em>logia</em>, meaning 'study of')</p>

        <p class="about-text">New companies produce new ontologies — conceptual frames — that serve as entry points to rich intellectual worlds. Writing independent field studies of ambitious early stage companies from a product-centric, deeply personal lens.</p>

      </div>

      <div class="about-links">
        <a href="https://www.startingfromnix.com/" class="about-link" target="_blank" rel="noopener">
          Substack
          <span class="about-link-arrow">↗</span>
        </a>
        <a href="https://x.com/startingfromnix" class="about-link" target="_blank" rel="noopener">
          Twitter
          <span class="about-link-arrow">↗</span>
        </a>
        <a href="mailto:startingfromnix@gmail.com" class="about-link">
          Email
          <span class="about-link-arrow">↗</span>
        </a>
      </div>

      <div class="about-photo-bottom">
        <div class="about-photo-bottom-img">
          <img src="/images/headshot.jpg" alt="Nicole Seah" />
        </div>
        <div class="about-photo-bottom-text">Nicole is a writer and investor based in San Francisco, California. You can find her writing on <a href="http://www.startingfromnix.com" target="_blank" rel="noopener">startingfromnix.com</a></div>
      </div>
    </div>

  </div>
</Base>

<style>
  .about-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2.5rem 4rem;
  }

  .about-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .about-eyebrow {
    display: block;
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-400);
    margin-bottom: 0.5rem;
  }

  .about-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--black);
  }

  .about-body {
    padding-top: 2.5rem;
  }

  .about-content {
    margin-bottom: 2.5rem;
  }

  .about-lead {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 1.75rem;
  }

  .about-text {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.05rem;
    color: var(--black);
    line-height: 1.8;
    margin-bottom: 1.1rem;
  }

  .about-text a {
    color: var(--black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .about-principles {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.05rem;
    color: var(--black);
    line-height: 1.8;
    padding-left: 1.25rem;
    margin-top: 0.25rem;
  }

  .about-principles li {
    margin-bottom: 0.25rem;
  }

  .about-photo-bottom {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .about-photo-bottom-img {
    width: 100px;
    height: 100px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .about-photo-bottom-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-photo-bottom-text {
    font-size: 0.88rem;
    color: var(--black);
    font-style: normal;
    font-family: var(--font-body);
    line-height: 1.6;
  }

  .about-photo-bottom-text a {
    color: var(--black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .about-bio-lead {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 1.75rem;
  }

  .about-bio-text {
    font-size: 0.9rem;
    color: var(--gray-500);
    line-height: 1.75;
  }

  .about-bio-text p {
    margin-bottom: 1.1rem;
  }

  .about-links {
    display: flex;
    gap: 0;
    margin-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .about-link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.85rem 1.25rem 0.85rem 0;
    margin-right: 1.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-500);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .about-link:hover {
    color: var(--black);
    border-bottom-color: var(--black);
  }

  .about-link-arrow {
    font-size: 0.85rem;
    transition: transform 0.2s;
  }

  .about-link:hover .about-link-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 740px) {
    .about-page { padding: 0 1.25rem 3rem; }
    .about-header { padding: 2rem 0 1.5rem; }
    .about-photo-bottom { flex-direction: column; text-align: center; }
    .about-photo-bottom-img { width: 100px; height: 100px; }
  }
</style>
