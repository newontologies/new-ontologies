---
import Base from '../layouts/Base.astro';

// Get all markdown posts, sorted by date descending
const allPosts = await Astro.glob('./posts/*.md');
const posts = allPosts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<Base>
  <div class="container">
    <div class="index-header">
      <h1>New Ontologies</h1>
      <p>Original research on companies.</p>
    </div>
    <ul class="post-list">
      {posts.map((post) => {
        const date = new Date(post.frontmatter.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
        });
        return (
          <li class="post-item">
            <div>
              <h2 class="post-item-title">
                <a href={post.url}>{post.frontmatter.title}</a>
              </h2>
              {post.frontmatter.subtitle && (
                <p class="post-item-excerpt">{post.frontmatter.subtitle}</p>
              )}
              {post.frontmatter.tag && (
                <span class="post-tag">{post.frontmatter.tag}</span>
              )}
            </div>
            <span class="post-item-meta">{date}</span>
          </li>
        );
      })}
    </ul>
  </div>
</Base>
