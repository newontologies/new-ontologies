---
import Base from '../layouts/Base.astro';

const allPosts = await Astro.glob('./posts/*.md');
const posts = allPosts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
const [featured, ...rest] = posts;
---
<Base>
  <!-- HERO -->
  <div class="hero-c">
    <div class="hero-c-image">
      <img src="/images/halftone-bridge.jpg" alt="Golden Gate Bridge in halftone" />
    </div>
    <div class="hero-c-overlay"></div>
  </div>

  <!-- ABOUT (style C) -->
  <div class="about-c">
    <strong class="about-c-bold">How do we talk more ambitiously about the future?</strong>
    <p class="about-c-text">Long-form field studies of founders and early stage teams</p>
  </div>

  <!-- FEATURED POST -->
  {featured && (
    <div class="container">
      <a class="feat-card" href={featured.url}>
        <div class="feat-img">
          <img src={featured.frontmatter.image || '/images/teampic.jpg'} alt={featured.frontmatter.title} />
        </div>
        <div class="feat-body">
          <div>
            <h2 class="feat-title">{featured.frontmatter.title}</h2>
            {featured.frontmatter.subtitle && <p class="feat-sub">{featured.frontmatter.subtitle}</p>}
          </div>
          <span class="feat-meta">
            {new Date(featured.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
          </span>
        </div>
      </a>

      <!-- REMAINING POSTS -->
      <ul class="thumb-list">
        {rest.map((post) => {
          const date = new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
          return (
            <li class="thumb-item">
              <div class="thumb-img">
                <img src={post.frontmatter.image || '/images/sara_bw.jpg'} alt={post.frontmatter.title} />
              </div>
              <div>
                <h2 class="thumb-title"><a href={post.url}>{post.frontmatter.title}</a></h2>
                {post.frontmatter.subtitle && <p class="thumb-sub">{post.frontmatter.subtitle}</p>}
                {post.frontmatter.tag && <span class="post-tag">{post.frontmatter.tag}</span>}
              </div>
              <span class="thumb-meta">{date}</span>
            </li>
          );
        })}
      </ul>
    </div>
  )}

</Base>
