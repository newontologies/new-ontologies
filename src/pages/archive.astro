---
import Base from '../layouts/Base.astro';

const allPosts = await Astro.glob('./posts/*.md');
const posts = allPosts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

// Group by year
const byYear: Record<string, typeof posts> = {};
for (const post of posts) {
  const year = new Date(post.frontmatter.date).getFullYear().toString();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(post);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---
<Base title="Archive">
  <div class="archive-page">

    <div class="archive-header">
      <span class="archive-eyebrow">Archive</span>
      <h1 class="archive-title">All writing</h1>
    </div>

    {years.map(year => (
      <div class="archive-year-group">
        <div class="archive-year-row">
          <span class="archive-year">{year}</span>
        </div>
        <ul class="archive-list">
          {byYear[year].map(post => {
            const date = new Date(post.frontmatter.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            return (
              <li class="archive-item">
                <a href={post.url} class="archive-item-link">
                  <span class="archive-item-date">{date}</span>
                  <span class="archive-item-title">{post.frontmatter.title}</span>
                  {post.frontmatter.subtitle && (
                    <span class="archive-item-sub">{post.frontmatter.subtitle}</span>
                  )}
                  {post.frontmatter.tag && (
                    <span class="archive-item-tag">{post.frontmatter.tag.split(',')[0].trim()}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

  </div>
</Base>

<style>
  .archive-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2.5rem 5rem;
  }

  .archive-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 0;
  }

  .archive-eyebrow {
    display: block;
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-400);
    margin-bottom: 0.5rem;
  }

  .archive-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--black);
  }

  .archive-year-group {
    border-bottom: 1px solid var(--border-color);
  }

  .archive-year-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    padding: 1.5rem 0 0;
  }

  .archive-year {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-400);
  }

  .archive-list {
    list-style: none;
  }

  .archive-item {
    border-top: 1px solid var(--border-color);
  }

  .archive-item:first-child {
    border-top: none;
  }

  .archive-item-link {
    display: grid;
    grid-template-columns: 64px 1fr auto auto;
    gap: 0 1.25rem;
    align-items: baseline;
    padding: 1.1rem 0;
    text-decoration: none;
    transition: background 0.15s;
  }

  .archive-item-link:hover .archive-item-title {
    color: var(--black);
  }

  .archive-item-date {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    padding-top: 0.15rem;
  }

  .archive-item-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--black);
    transition: color 0.2s;
  }

  .archive-item-sub {
    font-size: 0.75rem;
    color: var(--gray-500);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-top: 0.2rem;
  }

  .archive-item-tag {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    white-space: nowrap;
    align-self: center;
  }

  @media (max-width: 740px) {
    .archive-page { padding: 0 1.25rem 3rem; }
    .archive-header { padding: 2rem 0 1.5rem; }
    .archive-year-row { grid-template-columns: 52px 1fr; padding: 1.25rem 0 0; }
    .archive-year-group { border-bottom: none; }
    .archive-item-link {
      grid-template-columns: 52px 1fr;
      grid-template-rows: auto auto;
      gap: 0.1rem 0.75rem;
    }
    .archive-item-sub { display: none; }
    .archive-item-tag { grid-column: 2; font-size: 0.58rem; }
  }
</style>
