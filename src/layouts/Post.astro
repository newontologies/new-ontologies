---
import Base from './Base.astro';

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Base title={frontmatter.title} description={frontmatter.subtitle || frontmatter.title}>
  <div class="container">
    <article>
      <header class="post-header">
        {frontmatter.tag && <div class="post-header-tag">{frontmatter.tag}</div>}
        <h1>{frontmatter.title}</h1>
        {frontmatter.subtitle && <p class="post-header-subtitle">{frontmatter.subtitle}</p>}
        <div class="post-header-meta">{formattedDate}</div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</Base>
