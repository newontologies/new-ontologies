---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'New Ontologies', description = 'Original research on companies.' } = Astro.props;
const pageTitle = title === 'New Ontologies' ? title : `${title} — New Ontologies`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">New Ontologies</a>
      <nav class="site-nav">
        <a href="/">Archive</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <span>&copy; {new Date().getFullYear()} New Ontologies</span>
      <a href="https://yourusername.substack.com" target="_blank" rel="noopener">Substack</a>
    </div>
  </footer>
</body>
</html>
